# ============== SQL Server ==============
# SA password must satisfy SQL Server complexity rules (8+ chars,
# upper/lower/digit/symbol).
MSSQL_SA_PASSWORD=StrongPassw0rd!
MZ_SQLSERVER_PASSWORD=MzPassw0rd!
MSSQL_PORT=1433

# ============== Materialize ==============
MZ_PORT=6875
MZ_CONSOLE_PORT=6874

# ============== Services ==============
API_PORT=8080
AGENT_PORT=8081
SIM_CONTROL_PORT=8085
WEB_PORT=5173

# ============== Copilot LLM ==============
# Set at least one. Anthropic is preferred when both are present.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Optional override, e.g. claude-sonnet-5
AGENT_MODEL=

# ============== Web ==============
VITE_API_URL=http://localhost:8080
VITE_AGENT_URL=http://localhost:8081
ALLOWED_ORIGINS=http://localhost:5173
